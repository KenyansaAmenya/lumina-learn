{
    "version": 2,
    "builds": [
        {
            "src": "backend/main.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.9"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/api/(.*)",
            "dest": "backend/main.py"
        },
        {
            "src": "/teacher-dashboard",
            "dest": "/teacher-dashboard.html"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}